@using Microsoft.AspNetCore.Components.Forms
@using OP_Shared_Library.Services
@inject EditModeService EditModeService

@if (EditModeService.IsEditing)
{
    <div class="gallery-actions">
        <button class="gallery-add-btn" @onclick="OpenNew" title="Přidat fotku" aria-label="Přidat fotku">
            <svg viewBox="0 0 24 24" aria-hidden="true">
                <path d="M12 5v14M5 12h14" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" />
            </svg>
        </button>
    </div>
}

@if (EditPhotoGalleryService.Items.Count > 0)
{
    @* IMAGE GALLERY *@
    <div class="gallery">
        @foreach (var image in EditPhotoGalleryService.Items)
        {
            <div class="gallery-item" @onclick="() => OpenImage(image)">
                @{
                    var srcSet = GetImageSrcSet(image);
                    var sizes = GetResponsiveSizes(srcSet);
                }

                <img src="@GetImageSource(image)" alt="Gallery Image" srcset="@srcSet" sizes="@sizes" />
            </div>
        }
    </div>
}

@if (isBusy)
{
    <div class="busy-overlay" role="alert" aria-live="assertive" aria-busy="true">
        <div class="busy-card">
            <div class="busy-spinner"></div>

            @if (uploadProgress > 0 && uploadProgress < 100)
            {
                <div class="busy-progress">
                    <div class="busy-progress-bar" style="width:@($"{uploadProgress}%")"></div>
                </div>
            }

            @if (isAwaitingFile)
            {
                <button class="btn" @onclick="CancelBusy">Zavřít</button>
            }
        </div>
    </div>
}

@if (IsModalOpen)
{@* MODAL WINDOW *@
    if (!EditModeService.IsEditing)
    {
        <div class="modal-overlay">
            <div class="modal-content" tabindex="0"
                 @onkeydown="Move"
                 @ontouchstart="HandleTouchStart"
                 @ontouchend="HandleTouchEnd">
                <button class="modal-close"
                        @onclick="CloseModal"
                        aria-label="Close gallery">
                    <svg viewBox="0 0 24 24" aria-hidden="true">
                        <path d="M6 6l12 12M18 6L6 18" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" />
                    </svg>
                </button>
                @if (SelectedImage is not null)
                {
                    var srcSet = GetImageSrcSet(SelectedImage);
                    var sizes = GetResponsiveSizes(srcSet);

                        <button class="gallery-nav prev"
                                @onclick="MovePrevious"
                                aria-label="Previous image">
                            <svg viewBox="0 0 24 24" aria-hidden="true">
                                <path d="M15.5 19l-7-7 7-7" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" />
                            </svg>
                        </button>

                    <img src="@GetImageSource(SelectedImage)" alt="Full Image" class="full-image" srcset="@srcSet" sizes="@sizes" />

                        <button class="gallery-nav next"
                                @onclick="MoveNext"
                                aria-label="Next image">
                            <svg viewBox="0 0 24 24" aria-hidden="true">
                                <path d="M8.5 5l7 7-7 7" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" />
                            </svg>
                        </button>

                    <p class="image-caption mt_less">@SelectedImage.ImageTitle</p>
                }
            </div>
        </div>
    }
    else
    {
        @* EDIT MODAL WINDOW *@
        <div class="modal-backdrop">
            <div class="modal">
                <div class="modal-header">
                    <h2>EDIT PHOTO GALLERY</h2>
                </div>

                <label>Název:</label>
                <input @bind="draft.ImageTitle" />

                <label>Aktuální obrázek:</label>
                @if (!string.IsNullOrEmpty(draft.ImagePath))
                {
                    <img src="@draftPreview" alt="Aktuální obrázek" class="preview-img" />
                }

                <label class="btn" for="news-upload" @onclick="BeginUpload" disabled="@isBusy">
                    Nahrát nový obrázek
                </label>

                <InputFile id="news-upload"
                           hidden
                           OnChange="HandleImageChange" />

                <div class="modal-actions">
                    <button class="btn" @onclick="CloseModal">Zrušit</button>
                    @if (!IsNew)
                    {
                        <button class="btn" @onclick="Delete" disabled="@(SelectedImage is null)">Smazat</button>
                    }
                    <button class="btn" @onclick="SaveEdit">Uložit</button>
                </div>
            </div>
        </div>
    }
}
