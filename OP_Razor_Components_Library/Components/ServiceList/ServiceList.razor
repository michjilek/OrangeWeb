@using OP_Razor_Components_Library.Components.EditableImage
@using OP_Razor_Components_Library.Components.EditableText

<div class="container">
    @if (ServicesService.Items == null)
    {
        <div class="d-flex align-items-center gap-2">
            <div class="spinner-border spinner-border-sm" role="status" aria-hidden="true"></div>
            <span>Načítám…</span>
        </div>
    }
    else
    {
        @if (EditModeService.IsEditing)
        {
            <!-- Přidat službu -->
            <button class="btn btn-dark" @onclick="AddService" disabled="@isSaving">
                @TranslationsService.GetText("Services_AddService")
            </button>
        }

        <div class="service-list__table-wrap">
            <table class="table">
                <thead>
                    <tr>
                        <th><EditableText Id="Services_Image" EditMode="@EditModeService.IsEditing" /></th>
                        <th><EditableText Id="Services_Service" EditMode="@EditModeService.IsEditing" /></th>
                        <th><EditableText Id="Services_Description" EditMode="@EditModeService.IsEditing" /></th>
                        <th><EditableText Id="Services_Price" EditMode="@EditModeService.IsEditing" /></th>
                        <th><EditableText Id="Services_QRCode" EditMode="@EditModeService.IsEditing" /></th>
                        @if (EditModeService.IsEditing)
                        {
                            <th style="width:1%"></th>
                        }
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in ServicesService.Items)
                    {
                        <tr>
                            <td class="service-list__image-cell" data-label="@TranslationsService.GetText("Services_Image")">
                                <div class="service-list__image-wrapper">
                                    <EditableImage Key="@item.ImageKey" Sizes="96px" @key="item.ImageKey">
                                        <ImageContent Context="image">
                                            @if (string.IsNullOrWhiteSpace(image.Src))
                                            {
                                                <div class="service-list__image-placeholder">IMG</div>
                                            }
                                            else
                                            {
                                                <button type="button"
                                                        class="service-list__image-button"
                                                        aria-label="@GetServiceImageAlt(item)">
                                                    <img src="@image.Src"
                                                         srcset="@image.SrcSet"
                                                         sizes="@image.Sizes"
                                                         alt="@GetServiceImageAlt(item)"
                                                         class="service-list__service-image" />
                                                </button>
                                            }
                                        </ImageContent>
                                    </EditableImage>
                                </div>
                            </td>
                            <td data-label="@TranslationsService.GetText("Services_Service")">
                                @if (EditModeService.IsEditing)
                                {
                                    <input class="form-control" @bind="item.Name" disabled="@isSaving" />
                                }
                                else
                                {
                                    @item.Name
                                }
                            </td>
                            <td data-label="@TranslationsService.GetText("Services_Description")">
                                @if (EditModeService.IsEditing)
                                {
                                    <textarea class="form-control" @bind="item.Description" disabled="@isSaving"></textarea>
                                }
                                else
                                {
                                    <div style="white-space: pre-line;">@item.Description</div>
                                }
                            </td>
                            <td data-label="@TranslationsService.GetText("Services_Price")">
                                @if (EditModeService.IsEditing)
                                {
                                    <input class="form-control" @bind="item.Price" disabled="@isSaving" />
                                }
                                else
                                {
                                    @item.Price
                                }
                            </td>
                            <td class="service-list__qr-cell" data-label="@TranslationsService.GetText("Services_QRCode")">
                                <div class="service-list__qr-wrapper">
                                    <EditableImage Key="@item.QrCodeKey" Sizes="96px" @key="item.QrCodeKey">
                                        <ImageContent Context="image">
                                            @if (string.IsNullOrWhiteSpace(image.Src))
                                            {
                                                <div class="service-list__qr-placeholder">QR</div>
                                            }
                                            else
                                            {
                                                <button type="button"
                                                        class="service-list__qr-button"
                                                        @onclick="() => OpenQrModal(image.Src, GetQrImageAlt(item))"
                                                        aria-label="@GetQrOpenLabel(item)">
                                                    <img src="@image.Src"
                                                         srcset="@image.SrcSet"
                                                         sizes="@image.Sizes"
                                                         alt="@GetQrImageAlt(item)"
                                                         class="service-list__qr-image" />
                                                </button>
                                            }
                                        </ImageContent>
                                    </EditableImage>
                                </div>
                            </td>
                            @if (EditModeService.IsEditing)
                            {
                                <td class="text-end" data-label="@TranslationsService.GetText("Services_Delete")">
                                    <button class="btn btn-outline-danger"
                                            @onclick="() => RemoveService(item)"
                                            disabled="@isSaving">
                                        @TranslationsService.GetText("Services_Delete")
                                    </button>
                                </td>
                            }
                        </tr>
                    }
                </tbody>
            </table>
        </div>

        @if (EditModeService.IsEditing)
        {
            <!-- Uložit -->
            <button class="btn btn-dark" @onclick="Save" disabled="@isSaving">
                @if (isSaving)
                {
                    <span class="spinner me-2"></span>
                    <span>@TranslationsService.GetText("Services_Saving")</span>
                }
                else
                {
                    <span>@TranslationsService.GetText("Services_Save")</span>
                }
            </button>
        }
    }
</div>

@if (showToast)
{
    <div class="position-fixed bottom-0 end-0 p-3" style="z-index:1080;">
        <div class="toast show align-items-center @ToastBgClass border-0" role="status" aria-live="polite">
            <div class="d-flex">
                <div class="toast-body">
                    @toastMessage
                </div>
            </div>
        </div>
    </div>
}

@if (isQrModalOpen && !string.IsNullOrWhiteSpace(selectedQrImageSrc))
{
    <div class="service-list__modal-overlay" @onclick="CloseQrModal">
        <div class="service-list__modal-content" @onclick:stopPropagation="true">
            <button type="button"
                    class="service-list__modal-close"
                    @onclick="CloseQrModal"
                    aria-label="Close QR preview">
                <svg viewBox="0 0 24 24" aria-hidden="true">
                    <path d="M6 6l12 12M18 6L6 18" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" />
                </svg>
            </button>

            <img src="@selectedQrImageSrc"
                 alt="@selectedQrImageAlt"
                 class="service-list__modal-image" />
        </div>
    </div>
}

