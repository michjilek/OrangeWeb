@using Microsoft.Extensions.Hosting
@using Microsoft.JSInterop
@using System.Net
@inject IHostEnvironment env
@inject IJSRuntime JSRuntime
@inject TranslationsService TranslationsService
@implements IAsyncDisposable

@if (EditMode)
{
    @if (_editing)
    {
        <div class="overlay">
            <div class="edit_area">
                <div class="toolbar" role="toolbar" aria-label="Formátování textu">
                    <button class="tool-btn" type="button" title="Tučné" @onclick="ApplyBoldAsync">
                        <span class="material-symbols-outlined">format_bold</span>
                    </button>
                    <button class="tool-btn" type="button" title="Kurzíva" @onclick="ApplyItalicAsync">
                        <span class="material-symbols-outlined">format_italic</span>
                    </button>
                    <button class="tool-btn" type="button" title="Podtržení" @onclick="ApplyUnderlineAsync">
                        <span class="material-symbols-outlined">format_underlined</span>
                    </button>
                    <button class="tool-btn" type="button" title="Odkaz" @onclick="PromptForLinkAsync">
                        <span class="material-symbols-outlined">link</span>
                    </button>
                    <label class="tool-select" title="Velikost textu">
                        <span class="material-symbols-outlined">format_size</span>
                        <select @onchange="OnFontSizeChanged">
                            <option value="3">Normální</option>
                            <option value="2">Menší</option>
                            <option value="4">Větší</option>
                            <option value="5">Velký</option>
                        </select>
                    </label>
                    <label class="tool-color" title="Barva textu">
                        <span class="material-symbols-outlined">format_color_text</span>
                        <input type="color" value="#333333" @oninput="OnTextColorChanged" />
                    </label>
                    <button class="tool-btn" type="button" title="Vyčistit formátování" @onclick="ClearFormattingAsync">
                        <span class="material-symbols-outlined">format_clear</span>
                    </button>
                </div>

                <div class="editor-surface"
                     contenteditable="true"
                     @ref="_editorRef">
                </div>

                <div class="button-group">
                    <button class="btn" type="button" @onclick="CancelEdit">Zrušit</button>
                    <button class="btn" type="button" @onclick="SaveAsync">Uložit</button>
                </div>
            </div>
        </div>
    }

    <span @onclick="OpenEditor"
          class="editable-span rich-preview">@((MarkupString)FormatForDisplay(_translation))</span>
}
else
{
    <span class="rich-preview">@((MarkupString)FormatForDisplay(_translation))</span>
}

@code {
    [Parameter] public string Id { get; set; } = string.Empty;
    [Parameter] public bool EditMode { get; set; }

    private string _translation = string.Empty;
    private string _originalTranslation = string.Empty;
    private bool _editing;
    private bool _subscribed;
    private bool _shouldLoadEditor;
    private ElementReference _editorRef;
    private IJSObjectReference? _module;

    protected override void OnInitialized()
    {
        if (!_subscribed)
        {
            TranslationsService.OnChange += TranslationChanged;
            _subscribed = true;
        }
    }

    protected override void OnParametersSet()
    {
        ReloadValue();
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (_module is null)
        {
            _module = await JSRuntime.InvokeAsync<IJSObjectReference>(
                "import",
                "./_content/OP_Razor_Components_Library/Components/EditableRichText/EditableRichText.razor.js");
        }

        if (_editing && _shouldLoadEditor && _module is not null)
        {
            await _module.InvokeVoidAsync("setHtml", _editorRef, ToEditorHtml(_translation));
            await _module.InvokeVoidAsync("focusEditor", _editorRef);
            _shouldLoadEditor = false;
        }
    }

    public async ValueTask DisposeAsync()
    {
        if (_subscribed)
        {
            TranslationsService.OnChange -= TranslationChanged;
        }

        if (_module is not null)
        {
            try
            {
                await _module.DisposeAsync();
            }
            catch (JSDisconnectedException)
            {
            }
        }
    }

    private void ReloadValue()
    {
        _translation = TranslationsService.GetText(Id);
        _originalTranslation = _translation;
    }

    private void OpenEditor()
    {
        _editing = true;
        _shouldLoadEditor = true;
    }

    private async Task SaveAsync()
    {
        if (_module is not null)
        {
            _translation = await _module.InvokeAsync<string>("getHtml", _editorRef);
        }

        await TranslationsService.UpdateTranslationAsync(Id, _translation, env.ContentRootPath);
        _originalTranslation = _translation;
        _editing = false;
    }

    private void CancelEdit()
    {
        _translation = _originalTranslation;
        _editing = false;
        _shouldLoadEditor = false;
    }

    private async Task ApplyCommandAsync(string command)
    {
        if (_module is not null)
        {
            await _module.InvokeVoidAsync("applyCommand", _editorRef, command);
        }
    }

    private Task ApplyBoldAsync() => ApplyCommandAsync("bold");
    private Task ApplyItalicAsync() => ApplyCommandAsync("italic");
    private Task ApplyUnderlineAsync() => ApplyCommandAsync("underline");
    private Task ClearFormattingAsync() => ApplyCommandAsync("removeFormat");

    private async Task PromptForLinkAsync()
    {
        if (_module is not null)
        {
            await _module.InvokeVoidAsync("promptForLink", _editorRef);
        }
    }

    private async Task OnTextColorChanged(ChangeEventArgs e)
    {
        var color = e.Value?.ToString() ?? "#333333";

        if (_module is not null)
        {
            await _module.InvokeVoidAsync("applyColor", _editorRef, color);
        }
    }

    private async Task OnFontSizeChanged(ChangeEventArgs e)
    {
        var size = e.Value?.ToString() ?? "3";

        if (_module is not null)
        {
            await _module.InvokeVoidAsync("applyFontSize", _editorRef, size);
        }
    }

    private static string ToEditorHtml(string value)
    {
        if (string.IsNullOrWhiteSpace(value))
        {
            return string.Empty;
        }

        if (LooksLikeHtml(value))
        {
            return value;
        }

        return WebUtility.HtmlEncode(value).Replace("\r\n", "<br>").Replace("\n", "<br>");
    }

    private static string FormatForDisplay(string value)
    {
        if (string.IsNullOrWhiteSpace(value))
        {
            return string.Empty;
        }

        if (LooksLikeHtml(value))
        {
            return value;
        }

        return WebUtility.HtmlEncode(value).Replace("\r\n", "<br>").Replace("\n", "<br>");
    }

    private static bool LooksLikeHtml(string value)
    {
        return value.Contains('<') && value.Contains('>');
    }

    private void TranslationChanged()
    {
        ReloadValue();
        InvokeAsync(StateHasChanged);
    }
}
