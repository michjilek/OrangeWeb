@using Microsoft.AspNetCore.Components.Forms
@using Microsoft.Extensions.Hosting
@using OP_Razor_Components_Library.Components.References.Services
@using OP_Shared_Library.Services
@using System.Linq
@inject EditModeService EditModeService
@inject EditReferencesService EditReferencesService
@inject TranslationsService TranslationsService
@inject IHostEnvironment Env
@inject IMinIoService MinIoService
@implements IDisposable

@namespace OP_Razor_Components_Library.Components.References

<section class="references-shell">
    @if (EditModeService.IsEditing)
    {
        <div class="references-toolbar">
            <button class="references-action references-action-primary" @onclick="OpenNew">+ Add reference</button>
        </div>
    }

    @if (EditReferencesService.Items.Count > 0)
    {
        <div class="references-list">
            @for (int i = 0; i < EditReferencesService.Items.Count; i++)
            {
                var item = EditReferencesService.Items[i];

                <article class="reference-card">
                    @if (EditModeService.IsEditing)
                    {
                        <div class="reference-controls">
                            <button class="reference-control" @onclick="() => MoveEarlier(i)" disabled="@(i == 0)" title="Move up">↑</button>
                            <button class="reference-control" @onclick="() => MoveLater(i)" disabled="@(i == EditReferencesService.Items.Count - 1)" title="Move down">↓</button>
                            <button class="reference-control" @onclick="() => OpenEditor(i)" title="Edit reference">✎</button>
                        </div>
                    }

                    <div class="reference-avatar-wrap">
                        @if (!string.IsNullOrWhiteSpace(GetDisplayUrl(item)))
                        {
                            var srcSet = GetResponsiveSrcSet(item);
                            var sizes = GetResponsiveSizes(srcSet);

                            <img src="@GetDisplayUrl(item)"
                                 alt="@item.Author"
                                 class="reference-avatar"
                                 srcset="@srcSet"
                                 sizes="@sizes" />
                        }
                        else
                        {
                            <div class="reference-avatar reference-avatar-placeholder" aria-hidden="true">
                                @GetAvatarInitials(item)
                            </div>
                        }
                    </div>

                    <div class="reference-body">
                        <p class="reference-text">@item.Text</p>

                        <div class="reference-meta">
                            <p class="reference-author">@item.Author</p>

                            @if (!string.IsNullOrWhiteSpace(item.Subtitle))
                            {
                                <p class="reference-subtitle">@item.Subtitle</p>
                            }
                        </div>
                    </div>
                </article>
            }
        </div>
    }
    else
    {
        <div class="references-empty">
            <p class="references-empty-title">Reference zatím nejsou přidané.</p>
            @if (EditModeService.IsEditing)
            {
                <button class="references-action references-action-primary" @onclick="OpenNew">+ Add first reference</button>
            }
        </div>
    }
</section>

@if (isBusy)
{
    <div class="busy-overlay" role="alert" aria-live="assertive" aria-busy="true">
        <div class="busy-card">
            <div class="busy-spinner"></div>

            @if (uploadProgress > 0 && uploadProgress < 100)
            {
                <div class="busy-progress">
                    <div class="busy-progress-bar" style="width:@($"{uploadProgress}%")"></div>
                </div>
            }

            @if (isAwaitingFile)
            {
                <button class="references-action" @onclick="CancelBusy">Close</button>
            }
        </div>
    </div>
}

@if (EditModeService.IsEditing && IsEditorOpen)
{
    <div class="modal-backdrop">
        <div class="modal">
            <div class="modal-header">
                <h2>@(IsNew ? "Add Reference" : "Edit Reference")</h2>
            </div>

            <label>Name:</label>
            <input @bind="draftAuthor" />

            <label>Subtitle:</label>
            <input @bind="draftSubtitle" />

            <label>Reference text:</label>
            <textarea class="reference-textarea" @bind="draftText"></textarea>

            <label>Current image:</label>
            @if (!string.IsNullOrEmpty(draftImageUrl))
            {
                <div class="preview-frame">
                    <img src="@draftImageUrl" alt="Current image" class="preview-img" />
                </div>
            }

            <label class="references-action references-action-primary" for="reference-upload" @onclick="BeginUpload">
                Upload New Image
            </label>

            <InputFile id="reference-upload"
                       hidden
                       OnChange="HandleImageChange" />

            <div class="modal-actions">
                <button class="references-action" @onclick="CancelEdit">Cancel</button>
                @if (!IsNew)
                {
                    <button class="references-action" @onclick="DeleteReference">Delete</button>
                }
                <button class="references-action references-action-primary" @onclick="SaveEdit">Save</button>
            </div>
        </div>
    </div>
}

@code {
    private int CurrentIndex;
    private bool IsEditorOpen;
    private bool IsNew;
    private IBrowserFile uploadedImage;
    private bool isBusy;
    private int uploadProgress;
    private bool isAwaitingFile;

    private string draftAuthor;
    private string draftSubtitle;
    private string draftText;
    private string draftImageUrl;
    private string draftImageObjectKey;

    private const int PreviewMaxWidth = 1600;

    protected override async Task OnInitializedAsync()
    {
        await TranslationsService.LoadAsync();
        await EditReferencesService.LoadAsync(TranslationsService.GetLanguage());

        TranslationsService.OnChange += TranslationChanged;
        EditModeService.OnEditModeChanged += HandleEditModeChanged;
    }

    public void Dispose()
    {
        EditModeService.OnEditModeChanged -= HandleEditModeChanged;
        TranslationsService.OnChange -= TranslationChanged;
    }

    private void OpenEditor(int index)
    {
        if (index < 0 || index >= EditReferencesService.Items.Count) return;

        CurrentIndex = index;
        var item = EditReferencesService.Items[index];
        draftAuthor = item.Author;
        draftSubtitle = item.Subtitle;
        draftText = item.Text;
        draftImageUrl = GetDisplayUrl(item);
        draftImageObjectKey = item.ImageUrl;
        uploadedImage = null;

        IsNew = false;
        IsEditorOpen = true;
    }

    private void OpenNew()
    {
        CurrentIndex = EditReferencesService.Items.Count;
        draftAuthor = string.Empty;
        draftSubtitle = string.Empty;
        draftText = string.Empty;
        draftImageUrl = string.Empty;
        draftImageObjectKey = string.Empty;
        uploadedImage = null;

        IsNew = true;
        IsEditorOpen = true;
    }

    private async Task SaveEdit()
    {
        if (string.IsNullOrWhiteSpace(draftAuthor) || string.IsNullOrWhiteSpace(draftText))
        {
            return;
        }

        isBusy = true;
        uploadProgress = 0;
        StateHasChanged();

        try
        {
            ReferenceItem item;

            if (IsNew)
            {
                item = new ReferenceItem
                {
                    Id = Guid.NewGuid()
                };
                EditReferencesService.Items.Add(item);
                CurrentIndex = EditReferencesService.Items.Count - 1;
            }
            else
            {
                if (CurrentIndex < 0 || CurrentIndex >= EditReferencesService.Items.Count) return;
                item = EditReferencesService.Items[CurrentIndex];
            }

            item.Author = draftAuthor ?? string.Empty;
            item.Subtitle = draftSubtitle ?? string.Empty;
            item.Text = draftText ?? string.Empty;

            if (uploadedImage != null)
            {
                var (objectKey, signedUrl) = await UploadImageToMinIoAsync(uploadedImage);
                if (!string.IsNullOrWhiteSpace(objectKey))
                {
                    item.ImageUrl = objectKey;
                    item.ImageSignedUrl = signedUrl;
                    draftImageObjectKey = objectKey;
                    draftImageUrl = signedUrl ?? string.Empty;
                }
            }
            else if (!string.IsNullOrWhiteSpace(draftImageObjectKey))
            {
                item.ImageUrl = draftImageObjectKey;
                item.ImageSignedUrl = await EditReferencesService.ResolveImageUrlAsync(draftImageObjectKey);
            }
            else
            {
                item.ImageUrl = string.Empty;
                item.ImageSignedUrl = null;
            }

            await EditReferencesService.SaveAsync(Env.ContentRootPath);

            IsEditorOpen = false;
            IsNew = false;
            uploadedImage = null;
        }
        finally
        {
            isBusy = false;
            StateHasChanged();
        }
    }

    private void CancelEdit()
    {
        IsEditorOpen = false;
        IsNew = false;
    }

    private async Task DeleteReference()
    {
        if (CurrentIndex < 0 || CurrentIndex >= EditReferencesService.Items.Count) return;

        EditReferencesService.RemoveItem(EditReferencesService.Items[CurrentIndex]);

        if (CurrentIndex >= EditReferencesService.Items.Count)
        {
            CurrentIndex = Math.Max(0, EditReferencesService.Items.Count - 1);
        }

        await EditReferencesService.SaveAsync(Env.ContentRootPath);

        IsEditorOpen = false;
        IsNew = false;
    }

    private async Task MoveEarlier(int index)
    {
        if (index <= 0 || index >= EditReferencesService.Items.Count) return;

        var item = EditReferencesService.Items[index];
        EditReferencesService.Items.RemoveAt(index);
        EditReferencesService.Items.Insert(index - 1, item);
        await EditReferencesService.SaveAsync(Env.ContentRootPath);
    }

    private async Task MoveLater(int index)
    {
        if (index < 0 || index >= EditReferencesService.Items.Count - 1) return;

        var item = EditReferencesService.Items[index];
        EditReferencesService.Items.RemoveAt(index);
        EditReferencesService.Items.Insert(index + 1, item);
        await EditReferencesService.SaveAsync(Env.ContentRootPath);
    }

    private void BeginUpload()
    {
        isBusy = true;
        isAwaitingFile = true;
        uploadProgress = 0;
        StateHasChanged();
    }

    private void CancelBusy()
    {
        isBusy = false;
        isAwaitingFile = false;
        uploadProgress = 0;
    }

    private string GetDisplayUrl(ReferenceItem item) =>
        item?.ImageSignedUrl ?? item?.ImageUrl ?? string.Empty;

    private string GetResponsiveSrcSet(ReferenceItem item)
    {
        return ResponsiveImageHelper.BuildSrcSet(MinIoService, item.ImageUrl);
    }

    private string GetResponsiveSizes(string srcSet)
    {
        return string.IsNullOrWhiteSpace(srcSet)
            ? null
            : "(min-width: 1280px) 120px, 96px";
    }

    private string GetAvatarInitials(ReferenceItem item)
    {
        if (string.IsNullOrWhiteSpace(item?.Author)) return "R";

        var parts = item.Author.Split(' ', StringSplitOptions.RemoveEmptyEntries);
        if (parts.Length == 1) return parts[0][0].ToString().ToUpperInvariant();

        return string.Concat(parts.Take(2).Select(p => char.ToUpperInvariant(p[0])));
    }

    private async Task UploadResponsiveVariantAsync(IBrowserFile file, string objectKey)
    {
        var maxWidth = ResponsiveImageHelper.VariantWidths.Max();

        foreach (var width in ResponsiveImageHelper.VariantWidths)
        {
            var resized = await file.RequestImageFileAsync(file.ContentType, width, ResponsiveImageHelper.MaxUploadedHeight);
            await using var readStream = resized.OpenReadStream(maxAllowedSize: 10_000_000);
            using var ms = new MemoryStream();
            await readStream.CopyToAsync(ms);
            ms.Position = 0;

            var key = width == maxWidth ? objectKey : ResponsiveImageHelper.BuildVariantKey(objectKey, width);
            await MinIoService.PutObjectAsync(key, ms, resized);
        }
    }

    private async Task<(string ObjectKey, string SignedUrl)> UploadImageToMinIoAsync(IBrowserFile file)
    {
        if (file is null)
        {
            return (string.Empty, null);
        }

        var ext = Path.GetExtension(file.Name);
        if (string.IsNullOrWhiteSpace(ext) || !MinIoService.AllowedImageExtensions.Contains(ext))
        {
            return (string.Empty, null);
        }

        await MinIoService.EnsureBucketAsync();

        var objectKey = ResponsiveImageHelper.BuildResponsiveObjectKey(EditReferencesService.MinIoFolder, ext);
        await UploadResponsiveVariantAsync(file, objectKey);
        var signedUrl = await EditReferencesService.ResolveImageUrlAsync(objectKey);

        return (objectKey, signedUrl);
    }

    private async Task HandleImageChange(InputFileChangeEventArgs e)
    {
        uploadedImage = e.File;
        draftImageObjectKey = null;

        isAwaitingFile = false;
        isBusy = true;
        uploadProgress = 0;
        StateHasChanged();
        await Task.Delay(1);

        try
        {
            var preview = await uploadedImage.RequestImageFileAsync(uploadedImage.ContentType, PreviewMaxWidth, ResponsiveImageHelper.MaxUploadedHeight);
            await using var stream = preview.OpenReadStream(maxAllowedSize: 10_000_000);
            using var ms = new MemoryStream();

            var buffer = new byte[80 * 1024];
            long readTotal = 0;
            int read;
            while ((read = await stream.ReadAsync(buffer, 0, buffer.Length)) > 0)
            {
                await ms.WriteAsync(buffer, 0, read);
                readTotal += read;
                uploadProgress = (int)(readTotal * 100 / preview.Size);

                if (readTotal % (512 * 1024) == 0)
                {
                    StateHasChanged();
                }
            }

            draftImageUrl = $"data:{preview.ContentType};base64,{Convert.ToBase64String(ms.ToArray())}";
            uploadProgress = 100;
        }
        finally
        {
            isBusy = false;
            isAwaitingFile = false;
            StateHasChanged();
        }
    }

    private void HandleEditModeChanged()
    {
        InvokeAsync(StateHasChanged);
    }

    private async void TranslationChanged()
    {
        await EditReferencesService.LoadAsync(TranslationsService.GetLanguage());
        StateHasChanged();
    }
}
