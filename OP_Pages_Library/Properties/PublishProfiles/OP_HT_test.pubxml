<?xml version="1.0" encoding="utf-8"?>
<!-- https://go.microsoft.com/fwlink/?LinkID=208121. -->
<Project>
	<PropertyGroup>
		<Configuration>Release</Configuration>
		<Platform>Any CPU</Platform>
		<PublishDir>\\192.168.0.11\Op_HT_test</PublishDir>
		<PublishUrl>\\192.168.0.11\Op_HT_test\</PublishUrl>
		<PublishProtocol>FileSystem</PublishProtocol>
		<WebPublishMethod>FileSystem</WebPublishMethod>
		<_TargetId>Folder</_TargetId>
		<RemoteServer>192.168.0.11</RemoteServer>
		<IisSiteName>test.havirovterapie.cz</IisSiteName>
		<IisAppPoolName>test.havirovterapie.cz</IisAppPoolName>
		<RemoteUsername>Administrator</RemoteUsername>
		<RemotePassword>ZFno7bMrVjgjHPX*P7MXsBoe</RemotePassword>
	</PropertyGroup>
	<!-- BEFORE publish: stop IIS (remote) -->
	<Target Name="StopIISBeforePublish" BeforeTargets="Publish">
		<Exec Command="powershell -NoProfile -ExecutionPolicy Bypass -Command &quot;$sec=ConvertTo-SecureString '$(RemotePassword)' -AsPlainText -Force; $cred=New-Object System.Management.Automation.PSCredential('$(RemoteUsername)',$sec); Invoke-Command -ComputerName '$(RemoteServer)' -Credential $cred -ScriptBlock { Import-Module WebAdministration; Stop-WebAppPool -Name '$(IisAppPoolName)' -ErrorAction SilentlyContinue; Stop-Website -Name '$(IisSiteName)' -ErrorAction SilentlyContinue }&quot;"/>
	</Target>

	<!-- AFTER publish: start IIS (remote) -->
	<Target Name="StartIISAfterPublish" AfterTargets="Publish">
		<Exec Command="powershell -NoProfile -ExecutionPolicy Bypass -Command &quot;&amp; { $sec=ConvertTo-SecureString '$(RemotePassword)' -AsPlainText -Force; $cred=New-Object System.Management.Automation.PSCredential('$(RemoteUsername)',$sec); Invoke-Command -ComputerName '$(RemoteServer)' -Credential $cred -ScriptBlock { Import-Module WebAdministration; Start-WebAppPool -Name '$(IisAppPoolName)' -ErrorAction SilentlyContinue; $deadline=(Get-Date).AddSeconds(5); while((Get-WebAppPoolState -Name '$(IisAppPoolName)').Value -ne 'Started' -and (Get-Date) -lt $deadline){ Start-Sleep -Milliseconds 1000 }; if((Get-WebAppPoolState -Name '$(IisAppPoolName)').Value -ne 'Started'){ Start-WebAppPool -Name '$(IisAppPoolName)' -ErrorAction SilentlyContinue; Start-Sleep -Seconds 5 }; if((Get-WebAppPoolState -Name '$(IisAppPoolName)').Value -ne 'Started'){ &amp; $env:windir\system32\inetsrv\appcmd.exe start apppool /apppool.name:'$(IisAppPoolName)'; Start-Sleep -Seconds 5 }; if((Get-WebAppPoolState -Name '$(IisAppPoolName)').Value -eq 'Started'){ Start-Website -Name '$(IisSiteName)' -ErrorAction SilentlyContinue } else { Write-Host 'AppPool is not started, skipping site start.' } } }&quot;" />
	</Target>
</Project>