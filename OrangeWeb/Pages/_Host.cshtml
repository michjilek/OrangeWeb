@page "/"
@using Microsoft.AspNetCore.Components.Web
@namespace OrangeWeb.Pages
@addTagHelper *, Microsoft.AspNetCore.Mvc.TagHelpers
@using Microsoft.Extensions.Options
@using OP_Shared_Library.Configurations
@using OrangeWeb.Services
@inject IOptions<CompanyBrandingOptions> BrandingOptions

@* Code to run at start*@
@{
    @* Get branding values to fill *@
    var branding = BrandingOptions.Value;
    var configuredTheme = branding.ThemeCssFile;

    // Build only the scoped CSS links needed for the initial server-rendered request.
    // This replaces the large OrangeWeb.styles.css bundle, which pulled in CSS for every page/component.
    //var initialScopedCssLinks = BuildInitialScopedCssLinks();
    ScopedCssService scopedCssService = new();

    // _Host.cshtml runs only for the initial HTTP request. Later Blazor route changes are covered
    // by matching <HeadContent> links inside each route component.
    // Determine the route being requested and add only the scoped CSS needed for that route.
    // This keeps the initial payload as small as possible, improving load performance.
    var path = (HttpContext.Request.Path.Value ?? "/").TrimEnd('/').ToLowerInvariant();
    if (string.IsNullOrEmpty(path))
    {
        path = "/";
    }

    var initialScopedCssLinks = scopedCssService.BuildInitialScopedCssLinks(branding, path);
}

<!DOCTYPE html>
<html lang="cs">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <meta name="description" content="@branding.SeoDescription">
    <title>@branding.WebSiteTitle</title>
    @*   <base href="/" /> *@

    <!-- OpenGraph and Twitter Card meta tags -->
    @* OpenGraph is a protocol created by Facebook that determines how a page is displayed when someone shares it on social media *@
    <meta property="og:title" content="@branding.WebSiteTitle">
    <meta property="og:description" content="@branding.SeoDescription">
    <meta property="og:url" content="@branding.CanonicalUrl">
    <meta property="og:locale" content="cs_CZ">
    <meta property="og:type" content="website">
    <meta property="og:site_name" content="@branding.WebSiteTitle">
    <meta property="og:title" content="@branding.WebSiteTitle">
    <meta property="og:description" content="@branding.SeoDescription">
    <meta property="og:url" content="@branding.CanonicalUrl">
    <meta name="twitter:card" content="summary_large_image">
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    @* 
    @if (!string.IsNullOrWhiteSpace(branding.OgImageUrl))
    {
        <meta property="og:image" content="@branding.OgImageUrl">
        <meta property="og:image:secure_url" content="@branding.OgImageUrl">
        <meta property="og:image:alt" content="@branding.OgImageAlt">
    }

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image">
    <meta name="twitter:title" content="@branding.WebSiteTitle">
    <meta name="twitter:description" content="@branding.SeoDescription">

    @if (!string.IsNullOrWhiteSpace(branding.OgImageUrl))
    {
        <meta name="twitter:image" content="@branding.OgImageUrl">
    } *@

    <!-- Favicon -->
    <link rel="icon" type="image/png" href="~/_branding/favicon/favicon-96x96.png" sizes="96x96" />
    <link rel="icon" type="image/svg+xml" href="~/_branding/favicon/favicon.svg" />
    <link rel="shortcut icon" href="~/_branding/favicon/favicon.ico" />
    <link rel="apple-touch-icon" sizes="180x180" href="~/_branding/favicon/apple-touch-icon.png" />

    <!-- Others -->
    <link rel="manifest" href="~/_branding/site.webmanifest" />
    <link rel="canonical" href="@branding.CanonicalUrl" />
    <link href="_content/OP_Pages_Library/css/app.css" rel="preload" as="style"
          onload="this.onload=null;this.rel='stylesheet'" />
    <noscript>
        <link href="_content/OP_Pages_Library/css/app.css" rel="stylesheet" />
    </noscript>
    <link href="_content/OP_Pages_Library/css/index.css" rel="preload" as="style"
          onload="this.onload=null;this.rel='stylesheet'" />
    <noscript>
        <link href="_content/OP_Pages_Library/css/index.css" rel="stylesheet" />
    </noscript>
    @* - add preload to non-critical css files
       - before these css had to be downloaded, before site was rendered and this causes slow render
       - these css file is now preload and doesnt block rendering
       - after the site is rendered, these css files are applied
       - nonscript is fallback for browsers with disabled javascript
    *@
    <link href="_content/OP_Pages_Library/css/general.css" rel="preload" as="style" asp-append-version="true"
          onload="this.onload=null;this.rel='stylesheet'" />
    <noscript>
        <link href="_content/OP_Pages_Library/css/general.css" rel="stylesheet" asp-append-version="true" />
    </noscript>
    @*  - this link _branding... is fake adress used only for theme read
        - it is used in program.cs, where we load right theme for brand
    *@
    <link 
          href="~/_branding/theme.css"
          rel="preload"
          as="style"
          onload="this.onload=null;this.rel='stylesheet'"
          data-base-href='@Url.Content("~/_branding/theme.css")' />
    <link id="custom-font-stylesheet"
          href="~/css/CustomFont.css"
          rel="preload"
          as="style"
          onload="this.onload=null;this.rel='stylesheet'"
          data-base-href='@Url.Content("~/css/CustomFont.css")' />
    <noscript>
        <link href="~/css/CustomFont.css" rel="stylesheet" />
    </noscript>

    @* Scoped CSS add *@
    @foreach (var scopedCssHref in initialScopedCssLinks)
    {
        @* Preload scoped CSS without making it render-blocking. The noscript link keeps styling intact when JavaScript is disabled. *@
        <link href="@scopedCssHref" rel="preload" as="style"
              onload="this.onload=null;this.rel='stylesheet'" />
        <noscript>
            <link href="@scopedCssHref" rel="stylesheet" />
        </noscript>
    }

    <component type="typeof(HeadOutlet)" render-mode="ServerPrerendered" />
</head>
<body>
    <main>
        <component type="typeof(App)" render-mode="Server" />
    </main>

    <!-- Blazor -->
    <script src="_framework/blazor.server.js"></script>

    @* Version update checker and Cache kicker *@
    <script src="~/js/update-checker.js" asp-append-version="true" defer></script>
</body>
</html>
